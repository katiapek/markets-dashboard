# Database
DATABASE_URL=postgresql://@localhost:5432/your_db_name
HEROKU_DATABASE_URL=postgres://user:password@host:5432/dbname

# CFTC API (https://publicreporting.cftc.gov)
CFTC_TOKEN=your-cftc-app-token

# Flask
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-string

# Security
ALLOWED_HOSTS=yourdomain.com,localhost
CSRF_ENABLED=True

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
